APP_IMAGE=ghcr.io/your-org/cfarm-ir-app:v1
WEBSERVER_IMAGE=ghcr.io/your-org/cfarm-ir-webserver:v1
APP_NAME=CFARM IR System
APP_ENV=production
APP_KEY=base64:replace-with-your-own-app-key
APP_DEBUG=false
APP_URL=http://your-server-or-domain
LOG_CHANNEL=stderr
APP_PORT=2019
DB_IMAGE=mysql:8.0
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_PORT_FORWARD=3308
DB_DATABASE=cfarm_ir
DB_USERNAME=itadmin
DB_PASSWORD=replace-with-strong-password
DB_ROOT_PASSWORD=replace-with-strong-root-password
